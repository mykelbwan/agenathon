NETWORK_NAME=testnet
PRIVATE_KEY=
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=Qwen/Qwen3-32B

DUTCH_AUCTION_ADDRESS=
DATA_PROVIDER_ADDRESS=

AGENTKIT_IDENTITY_ENABLED=true
PROVIDER_AGENT_NAME="AgentMarket Provider"
PROVIDER_AGENT_DESCRIPTION="AgentMarket provider agent that watches AuctionSnapped and fulfills orders on-chain."
PROVIDER_AGENT_METADATA=ipfs://agentmarket/provider-agent
PROVIDER_AGENT_CAPABILITIES=price-data,auction-fulfillment

CONSUMER_AUCTION_ID=
CONSUMER_URGENCY=medium
CONSUMER_HANDLER_GAS_LIMIT=5000000
CONSUMER_BUDGET_WEI=
CONSUMER_SUBSCRIPTION_RESERVE_WEI=32000000000000000000
# Optional override. Defaults to the auction's dataType.
# CONSUMER_TARGET_DATA_TYPE=
CONSUMER_AGENT_NAME=AgentMarket Consumer
CONSUMER_AGENT_DESCRIPTION="AgentMarket consumer agent that uses Hugging Face to choose a threshold and deploys ConsumerHandler."
CONSUMER_AGENT_METADATA=ipfs://agentmarket/consumer-agent
CONSUMER_AGENT_CAPABILITIES=analyze,bid,data-consumer

# Optional overrides for non-testnet or custom deployments.
# RPC_URL=
# CHAIN_ID=
# NETWORK_LABEL=
# AGENT_REGISTRY_ADDRESS=
# AGENT_EXECUTOR_ADDRESS=
# AGENT_MANAGER_ADDRESS=
# AGENT_VAULT_ADDRESS=
# PROVIDER_AGENT_ID=
# CONSUMER_AGENT_ID=
