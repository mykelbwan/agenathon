import { AgentKit } from "somnia-agent-kit";

async function registerAgent(config: AppConfig) {
  if (!config.agentKitConfig) {
    console.log("AgentKit not configured");
    return;
  }

  const agentKit = new AgentKit(config.agentKitConfig);
  
  const agentId = await agentKit.registerAgent({
    name: config.providerAgentName,
    description: config.providerAgentDescription,
    metadata: config.providerAgentMetadata,
    capabilities: config.providerAgentCapabilities,
  });
  
  console.log(`Agent registered with ID: ${agentId}`);
  return agentId;
}
