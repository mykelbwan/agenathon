## Consumer Agent Implementation

Consumer agents participate in auctions by analyzing prices and automatically executing trades. Here's how to build one:

### Step 1: Create a Consumer Agent Class

```typescript
// app/agents/src/consumer.ts
import { Contract, ethers, JsonRpcProvider, Wallet } from "ethers";
import { AppConfig } from "./shared/config";
import { DUTCH_AUCTION_ABI } from "./contracts/DutchAuctionABI";
import { CONSUMER_HANDLER_ABI } from "./contracts/ConsumerHandlerABI";
import axios from "axios";

export class ConsumerAgent {
  private wallet: Wallet;
  private provider: JsonRpcProvider;
  private dutchAuctionContract: Contract;
  private consumerHandlerContract: Contract | null = null;
  private config: AppConfig;
  private huggingFaceClient: any;

  constructor(config: AppConfig) {
    this.config = config;
    this.provider = new JsonRpcProvider(config.network.rpcUrl);
    this.wallet = new Wallet(config.privateKey, this.provider);

    this.dutchAuctionContract = new Contract(
      config.dutchAuctionAddress,
      DUTCH_AUCTION_ABI,
      this.wallet
    );

    // Initialize HuggingFace client for AI decision-making
    if (config.huggingFaceApiKey) {
      this.huggingFaceClient = axios.create({
        baseURL: "https://api-inference.huggingface.co/models",
        headers: {
          Authorization: `Bearer ${config.huggingFaceApiKey}`,
        },
      });
    }
  }

  async start(): Promise<void> {
    console.log("Consumer Agent Starting...");
    console.log(`Wallet: ${this.wallet.address}`);
    console.log(`Target Data Type: ${this.config.consumerTargetDataType}`);
    console.log(`Budget: ${ethers.formatEther(this.config.consumerBudgetWei || 0n)} ETH`);

    // Deploy ConsumerHandler if specified
    if (this.config.consumerAuctionId) {
      await this.deployConsumerHandler();
    }

    // Start monitoring auctions
    await this.watchAndAnalyzeAuctions();
  }

  private async deployConsumerHandler(): Promise<void> {
    console.log("Deploying ConsumerHandler contract...");

    try {
      const ConsumerHandlerFactory = new ethers.ContractFactory(
        CONSUMER_HANDLER_ABI,
        CONSUMER_HANDLER_BYTECODE,
        this.wallet
      );

      const consumerHandler = await ConsumerHandlerFactory.deploy(
        this.config.dutchAuctionAddress,
        this.config.dataProviderAddress,
        this.config.consumerBudgetWei,
        this.config.consumerTargetDataType,
        this.config.consumerHandlerGasLimit || 2000000n,
        {
          value: this.config.consumerSubscriptionReserveWei || ethers.parseEther("32"),
          gasLimit: 5000000,
        }
      );

      await consumerHandler.waitForDeployment();
      const address = await consumerHandler.getAddress();

      this.consumerHandlerContract = consumerHandler;
      console.log(`ConsumerHandler deployed at: ${address}`);

    } catch (error) {
      console.error("Failed to deploy ConsumerHandler:", error);
      throw error;
    }
  }

  private async watchAndAnalyzeAuctions(): Promise<void> {
    console.log("Monitoring auctions...");

    // Poll for active auctions periodically
    setInterval(async () => {
      try {
        const activeAuctions = await this.dutchAuctionContract.getActiveAuctions();
        
        if (activeAuctions.length === 0) {
          console.log("  No active auctions");
          return;
        }

        console.log(`Found ${activeAuctions.length} active auction(s)`);

        for (const auctionId of activeAuctions) {
          await this.analyzeAuction(auctionId);
        }
      } catch (error) {
        console.error("Error analyzing auctions:", error);
      }
    }, 6000); // Check every 6 seconds
  }

  private async analyzeAuction(auctionId: bigint): Promise<void> {
    try {
      const auction = await this.dutchAuctionContract.getAuction(auctionId);

      // Filter by data type
      if (auction.dataType !== this.config.consumerTargetDataType) {
        return;
      }

      console.log(`\nAnalyzing auction ${auctionId}:`);
      console.log(`   Data Type: ${auction.dataType}`);
      console.log(`   Current Price: ${ethers.formatEther(auction.currentPrice)} ETH`);
      console.log(`   Floor Price: ${ethers.formatEther(auction.floorPrice)} ETH`);

      // Use AI to decide if price is good
      const shouldBid = await this.shouldBidOnAuction(auction);

      if (shouldBid) {
        console.log(`   AI recommends bidding!`);
        await this.executeSnap(auctionId, auction.currentPrice);
      } else {
        console.log(`   Waiting for better price...`);
      }

    } catch (error) {
      console.error(`Error analyzing auction ${auctionId}:`, error);
    }
  }

  private async shouldBidOnAuction(auction: any): Promise<boolean> {
    try {
      if (!this.huggingFaceClient) {
        // Fallback: simple threshold comparison
        return auction.currentPrice <= (this.config.consumerBudgetWei || 0n);
      }

      // Use HuggingFace model for intelligent decision
      const analysis = await this.queryHuggingFace(
        `Analyze this auction: Price: ${ethers.formatEther(auction.currentPrice)} ETH, ` +
        `Floor: ${ethers.formatEther(auction.floorPrice)} ETH, ` +
        `Data Type: ${auction.dataType}. Should we bid? Answer only with YES or NO.`
      );

      return analysis.includes("YES");

    } catch (error) {
      console.error("Error in AI decision-making:", error);
      // Fallback to threshold
      return auction.currentPrice <= (this.config.consumerBudgetWei || 0n);
    }
  }

  private async queryHuggingFace(prompt: string): Promise<string> {
    try {
      const response = await this.huggingFaceClient.post(
        `/${this.config.huggingFaceModel}`,
        { inputs: prompt },
        { timeout: 30000 }
      );

      if (Array.isArray(response.data) && response.data[0]?.generated_text) {
        return response.data[0].generated_text;
      }

      return "";
    } catch (error) {
      console.error("HuggingFace query failed:", error);
      return "";
    }
  }

  private async executeSnap(auctionId: bigint, price: bigint): Promise<void> {
    try {
      console.log(`   Snapping auction ${auctionId} at ${ethers.formatEther(price)} ETH`);

      const tx = await this.dutchAuctionContract.snap(auctionId, {
        value: price,
        gasLimit: 500000,
      });

      console.log(`   Transaction: ${tx.hash}`);
      const receipt = await tx.wait();
      console.log(`   Snap executed! Block: ${receipt?.blockNumber}`);

    } catch (error) {
      console.error(`   Failed to snap auction:`, error);
    }
  }
}

export async function runConsumerAgent(config: AppConfig): Promise<void> {
  const agent = new ConsumerAgent(config);
  await agent.start();

  process.on("SIGINT", () => {
    console.log("\nConsumer Agent shutting down...");
    process.exit(0);
  });
}
```

