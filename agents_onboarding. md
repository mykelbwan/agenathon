## Provider Agent Implementation

Provider agents watch for auctions and fulfill data requests. Here's how to build one:

### Step 1: Create a Provider Agent Class

```typescript
// app/agents/src/provider.ts
import { Contract, ethers, JsonRpcProvider, Wallet } from "ethers";
import { AppConfig } from "./shared/config";
import { DATA_PROVIDER_ABI } from "./contracts/DataProviderABI";
import { DUTCH_AUCTION_ABI } from "./contracts/DutchAuctionABI";

export class ProviderAgent {
  private wallet: Wallet;
  private provider: JsonRpcProvider;
  private dataProviderContract: Contract;
  private dutchAuctionContract: Contract;
  private config: AppConfig;

  constructor(config: AppConfig) {
    this.config = config;
    this.provider = new JsonRpcProvider(config.network.rpcUrl);
    this.wallet = new Wallet(config.privateKey, this.provider);
    
    this.dataProviderContract = new Contract(
      config.dataProviderAddress,
      DATA_PROVIDER_ABI,
      this.wallet
    );
    
    this.dutchAuctionContract = new Contract(
      config.dutchAuctionAddress,
      DUTCH_AUCTION_ABI,
      this.wallet
    );
  }

  async start(): Promise<void> {
    console.log("Provider Agent Starting...");
    console.log(`Wallet: ${this.wallet.address}`);
    console.log(`DataProvider: ${this.config.dataProviderAddress}`);
    console.log(`DutchAuction: ${this.config.dutchAuctionAddress}`);

    // Subscribe to auction snapped events
    await this.watchAuctionSnappedEvents();
  }

  private async watchAuctionSnappedEvents(): Promise<void> {
    const filter = this.dutchAuctionContract.filters.AuctionSnapped();

    this.dutchAuctionContract.on(filter, async (auctionId, winner, finalPrice) => {
      console.log(
        `Auction ${auctionId} snapped at ${ethers.formatEther(finalPrice)} ETH by ${winner}`
      );

      try {
        await this.fulfillAuction(auctionId);
      } catch (error) {
        console.error(`Error fulfilling auction ${auctionId}:`, error);
      }
    });

    console.log("Listening for AuctionSnapped events...");
  }

  private async fulfillAuction(auctionId: bigint): Promise<void> {
    console.log(`Fulfilling auction ${auctionId}...`);

    try {
      // Get auction details
      const auction = await this.dutchAuctionContract.getAuction(auctionId);
      
      console.log(`  Data Type: ${auction.dataType}`);
      console.log(`  API URL: ${auction.apiUrl}`);
      console.log(`  JSON Selector: ${auction.jsonSelector}`);
      console.log(`  Decimals: ${auction.decimals}`);

      // Fetch data from external API
      const dataValue = await this.fetchExternalData(
        auction.apiUrl,
        auction.jsonSelector,
        auction.decimals
      );

      console.log(`  Fetched Value: ${dataValue}`);

      // Calculate required deposit
      const SUBCOMMITTEE_SIZE = 3n;
      const PER_AGENT_EXECUTION_COST = ethers.parseEther("0.03");
      const requestDeposit = await this.dataProviderContract.getRequestDeposit();
      const totalDeposit = requestDeposit + (PER_AGENT_EXECUTION_COST * SUBCOMMITTEE_SIZE);

      console.log(`  Required Deposit: ${ethers.formatEther(totalDeposit)} ETH`);

      // Call fulfillOrder
      const tx = await this.dataProviderContract.fulfillOrder(auctionId, {
        value: totalDeposit,
        gasLimit: 500000,
      });

      console.log(`  Transaction: ${tx.hash}`);
      const receipt = await tx.wait();
      console.log(`  Order fulfilled! Block: ${receipt?.blockNumber}`);

    } catch (error) {
      console.error(`Failed to fulfill auction ${auctionId}:`, error);
      throw error;
    }
  }

  private async fetchExternalData(
    apiUrl: string,
    jsonSelector: string,
    decimals: number
  ): Promise<bigint> {
    try {
      console.log(`  Fetching from ${apiUrl}...`);
      
      const response = await fetch(apiUrl);
      if (!response.ok) {
        throw new Error(`HTTP ${response.status}: ${response.statusText}`);
      }

      const data = await response.json();
      
      // Navigate to the value using JSON selector (e.g., "data.price.current")
      let value: number = data;
      for (const key of jsonSelector.split(".")) {
        value = value[key as keyof typeof value];
        if (value === undefined) {
          throw new Error(`Selector path '${jsonSelector}' not found in response`);
        }
      }

      // Convert to wei with specified decimals
      const bigIntValue = ethers.parseUnits(String(value), decimals);
      return bigIntValue;

    } catch (error) {
      console.error(`  Failed to fetch data:`, error);
      throw error;
    }
  }
}

export async function runProviderAgent(config: AppConfig): Promise<void> {
  const agent = new ProviderAgent(config);
  await agent.start();

  // Keep agent running
  process.on("SIGINT", () => {
    console.log("\nProvider Agent shutting down...");
    process.exit(0);
  });
}
```

### Step 2: Handle Agent Responses

The provider agent also needs to handle callbacks from the Somnia platform:

```typescript
// app/agents/src/provider-handler.ts
import { Contract, ethers, JsonRpcProvider, Wallet } from "ethers";
import { AppConfig } from "./shared/config";

export class ProviderResponseHandler {
  private wallet: Wallet;
  private dataProviderContract: Contract;
  private config: AppConfig;

  constructor(config: AppConfig, dataProviderContract: Contract) {
    this.config = config;
    this.dataProviderContract = dataProviderContract;
    this.wallet = dataProviderContract.runner as Wallet;
  }

  /**
   * Handle response from Somnia platform
   * This gets called by the DataProvider contract when agent execution completes
   */
  async handleResponse(
    requestId: bigint,
    responses: any[],
    status: number
  ): Promise<void> {
    console.log(`Response Handler triggered for request ${requestId}`);
    console.log(`   Status: ${status}`);
    console.log(`   Responses received: ${responses.length}`);

    // Status codes:
    // 1 = Pending
    // 2 = Success
    // 3 = Failed
    // 4 = TimedOut

    if (status === 2) {
      // Success
      console.log(`Request ${requestId} completed successfully`);
      if (responses.length > 0) {
        const result = responses[0].result;
        console.log(`   Result: ${result}`);
      }
    } else {
      console.log(`Request ${requestId} failed with status ${status}`);
    }
  }
}
```

