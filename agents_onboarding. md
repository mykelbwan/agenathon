## Example: Complete Provider Agent Workflow

```typescript
// Putting it all together
import { runProviderAgent } from "./provider";
import { loadAppConfig } from "./shared/config";

async function main() {
  try {
    // 1. Load configuration from environment
    const config = loadAppConfig(["", "", "provider"]);
    
    console.log("═══════════════════════════════════════");
    console.log("  Agenathon Provider Agent v1.0");
    console.log("═══════════════════════════════════════");
    console.log(`Network: ${config.networkName}`);
    console.log(`Wallet: ${config.privateKey.slice(0, 10)}...`);
    console.log(`Dutch Auction: ${config.dutchAuctionAddress}`);
    console.log(`Data Provider: ${config.dataProviderAddress}`);
    console.log("═══════════════════════════════════════\n");

    // 2. Start the agent
    await runProviderAgent(config);

  } catch (error) {
    console.error("Fatal error:", error);
    process.exit(1);
  }
}

main();
```

