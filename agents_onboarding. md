## Smart Contract Integration

### Key Contracts and Interfaces

#### 1. Dutch Auction Interface

```solidity
interface IDutchAuction {
    enum AuctionStatus { Active, Snapped, Expired }
    
    struct Auction {
        uint256 id;
        address provider;
        string dataType;
        string apiUrl;
        string jsonSelector;
        uint8 decimals;
        uint256 startPrice;
        uint256 floorPrice;
        uint256 currentPrice;
        uint256 priceStep;
        uint256 startBlock;
        uint256 timeoutBlocks;
        AuctionStatus status;
        address winner;
        uint256 escrowRef;
    }
    
    function startAuction(
        string calldata dataType,
        string calldata apiUrl,
        string calldata jsonSelector,
        uint8 decimals,
        uint256 startPrice,
        uint256 floorPrice,
        uint256 priceStep,
        uint256 timeoutBlocks
    ) external returns (uint256 auctionId);
    
    function snap(uint256 auctionId) external payable returns (bool);
    function getActiveAuctions() external view returns (uint256[] memory);
    function getAuction(uint256 auctionId) external view returns (Auction memory);
}
```

#### 2. Data Provider Interface

```solidity
interface IDataProvider {
    function fulfillOrder(uint256 auctionId) external payable;
    function handleResponse(
        uint256 requestId,
        Response[] memory responses,
        ResponseStatus status,
        Request memory request
    ) external;
}
```

#### 3. Escrow Interface

```solidity
interface IEscrow {
    function lockPayment(
        uint256 auctionId,
        address buyer,
        address provider,
        uint256 timeoutBlocks
    ) external payable;
    
    function release(uint256 auctionId) external;
    function claimRefund(uint256 auctionId) external;
}
```

### Creating New Auctions (For Data Providers)

```typescript
async function createDataAuction(
  dutchAuctionAddress: string,
  wallet: Wallet,
  dataDetails: {
    dataType: string;           // e.g., "ETH/USD"
    apiUrl: string;              // e.g., "https://api.coingecko.com/api/v3/simple/price"
    jsonSelector: string;        // e.g., "ethereum.usd"
    decimals: number;            // e.g., 18
    startPrice: bigint;          // e.g., parseEther("5")
    floorPrice: bigint;          // e.g., parseEther("0.5")
    priceStep: bigint;           // e.g., parseEther("0.1")
    timeoutBlocks: bigint;       // e.g., 1000n
  }
): Promise<bigint> {
  const contract = new Contract(dutchAuctionAddress, DUTCH_AUCTION_ABI, wallet);
  
  const tx = await contract.startAuction(
    dataDetails.dataType,
    dataDetails.apiUrl,
    dataDetails.jsonSelector,
    dataDetails.decimals,
    dataDetails.startPrice,
    dataDetails.floorPrice,
    dataDetails.priceStep,
    dataDetails.timeoutBlocks,
    { gasLimit: 300000 }
  );
  
  const receipt = await tx.wait();
  const log = receipt?.logs[0];
  
  // Extract auctionId from event
  const auctionId = BigInt(log?.topics[1] || 0);
  return auctionId;
}
```

